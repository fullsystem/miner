# Your Bitcoin wallet (bc1..., 1... or 3...) — required
WALLET=

# Percentage of CPU cores used by the miner (1-100)
POWER=50

# Worker name shown at the pool (useful with multiple instances)
WORKER_NAME=docker

# Dashboard password (optional; without it the panel is public read-only)
# DASHBOARD_PASSWORD=

# Custom engine (optional) — e.g. a GPU miner mounted via volume.
# Placeholders available in MINER_ARGS: {POOL}, {USER}, {THREADS}
# MINER_BIN=/opt/gpu-miner
# MINER_ARGS=--url {POOL} --user {USER} --pass x --gpu 0
