# Sua carteira Bitcoin (bc1..., 1... ou 3...) — obrigatória
WALLET=

# Percentual dos núcleos da CPU usados pelo minerador (1-100)
POWER=50

# Nome do worker na pool (útil com várias instâncias)
WORKER_NAME=docker

# Senha do dashboard (opcional; sem ela o painel é público somente-leitura)
# DASHBOARD_PASSWORD=

# Engine customizado (opcional) — ex. miner de GPU montado via volume.
# Placeholders disponíveis em MINER_ARGS: {POOL}, {USER}, {THREADS}
# MINER_BIN=/opt/gpu-miner
# MINER_ARGS=--url {POOL} --user {USER} --pass x --gpu 0
